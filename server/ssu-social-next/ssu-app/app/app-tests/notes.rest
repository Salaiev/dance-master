### ===============================
### VARIABLES
### ===============================
@base = http://localhost:3000/api
@user = 11111111-1111-1111-1111-111111111111
@lesson = aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa
@note = 385f653b-9039-4ccf-adc2-d9c2eb9d133f


### ===============================
### 1. List ALL my notes
### ===============================
GET {{base}}/notes?user_id={{user}}


### ===============================
### 2. List my notes for one lesson
### ===============================
GET {{base}}/notes?lessonId={{lesson}}&user_id={{user}}


### ===============================
### 3. Create a note
### ===============================
POST {{base}}/notes
Content-Type: application/json

{
  "lesson_id": "{{lesson}}",
  "user_id": "{{user}}",
  "content": "Keep shoulders relaxed. Count 1-2-3-4."
}


### ===============================
### 4. Update note
### ===============================
PATCH {{base}}/notes/{{note}}
Content-Type: application/json

{
  "user_id": "{{user}}",
  "content": "Updated note text."
}


### ===============================
### 5. Delete note
### ===============================
DELETE {{base}}/notes/{{note}}
Content-Type: application/json

{
  "user_id": "{{user}}"
}